# ==================== 應用設置 ====================
DEBUG=false
ENVIRONMENT=production
APP_NAME=台股觀測站
APP_VERSION=1.0.0

# ==================== API 設置 ====================
API_HOST=0.0.0.0
API_PORT=8000

# ==================== 資料庫設置 ====================
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tw_stock_observer
DB_POOL_SIZE=20

# ==================== Redis 設置 ====================
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== 快取設置 ====================
CACHE_TTL_QUOTE=300
CACHE_TTL_KLINE=3600
CACHE_TTL_PROFILE=86400

# ==================== JWT 設置 ====================
SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== CORS 設置 ====================
CORS_ORIGINS=https://your-domain.com
ALLOWED_HOSTS=your-domain.com

# ==================== 外部 API 設置 ====================
TWSE_API_TIMEOUT=30
TWSE_RETRY_COUNT=3
YAHOO_FINANCE_TIMEOUT=30

# ==================== 日誌設置 ====================
LOG_LEVEL=INFO

# ==================== 郵件設置 ====================
MAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==================== 監控設置 ====================
SENTRY_ENABLED=false
SENTRY_DSN=
